# Copie para secrets.env na raiz do repositório (ao lado de install-rpi.sh).
#   cp secrets.example secrets.env && nano secrets.env
# O arquivo secrets.env não deve ser commitado (está no .gitignore).
#
# Se você expôs chaves em algum lugar público, gere novas no Google AI / TMDB.

GEMINI_API_KEY=
TMDB_READ_ACCESS_TOKEN=
TMDB_API_KEY=

# Opcionais (install-rpi.sh preenche SECRET_KEY e bind se faltarem):
# SECRET_KEY=
# FLASK_BIND=0.0.0.0:8080
# GUNICORN_WORKERS=2
# GEMINI_MODEL=
# GEMINI_HTTP_TIMEOUT_MS=90000
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# CACHE_TYPE=SimpleCache
# CACHE_DIR=/var/cache/movies-app
