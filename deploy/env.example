# Gerado pelo install-rpi.sh a partir de secrets.env na raiz do repositório.
# Edite secrets.env (ou este arquivo) e rode de novo: sudo ./install-rpi.sh
#
# Variáveis esperadas (veja secrets.example):
#   TMDB_READ_ACCESS_TOKEN, TMDB_API_KEY, GEMINI_API_KEY
# O instalador acrescenta SECRET_KEY, FLASK_BIND e GUNICORN_WORKERS se faltarem.

TMDB_READ_ACCESS_TOKEN=
TMDB_API_KEY=
GEMINI_API_KEY=
SECRET_KEY=
FLASK_BIND=0.0.0.0:8080
# SSE usa filas em memória: mantenha 1 worker por instância (padrão no start-gunicorn.sh).
# Threads para gthread: GUNICORN_THREADS (ex.: 4).
GUNICORN_WORKERS=1
GUNICORN_THREADS=4
# Com Nginx na frente: na location do app use proxy_buffering off; e proxy_read_timeout 3600s
# para o stream SSE não ficar bufferizado nem cair por timeout.
# GEMINI_MODEL=
# GEMINI_HTTP_TIMEOUT_MS=90000
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# CACHE_TYPE=SimpleCache
# CACHE_DIR=
